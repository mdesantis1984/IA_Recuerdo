# IA_Recuerdo — Variables de entorno para producción
# Variables de entorno para producción
# Copia a /etc/ia-recuerdo/env y ajusta los valores

# Base de datos PostgreSQL
IA_DB_DRIVER=postgres
IA_DB_DSN=postgres://ia_recuerdo:CHANGE_ME@localhost:5432/ia_recuerdo?sslmode=require

# Transporte: ambos (stdio para agentes locales, HTTP para agentes remotos)
IA_TRANSPORT=both
IA_ADDR=:7438

# Caché Valkey (comentar si no está disponible)
# IA_VALKEY=localhost:6379

# Búsqueda semántica con pgvector (requiere Postgres + pgvector extension)
# Opción 1 — Ollama (self-hosted, recomendado):
# IA_EMBED_URL=http://ollama:11434/v1/embeddings
# IA_EMBED_MODEL=nomic-embed-text
# IA_EMBED_FORMAT=openai
# IA_EMBED_DIMS=768
#
# Opción 2 — OpenAI:
# IA_EMBED_URL=https://api.openai.com/v1/embeddings
# IA_EMBED_MODEL=text-embedding-3-small
# IA_EMBED_TOKEN=sk-...
# IA_EMBED_FORMAT=openai
# IA_EMBED_DIMS=1536

# Proyecto por defecto
IA_PROJECT=default
